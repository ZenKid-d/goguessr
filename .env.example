# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your own values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Mapillary client access token (looks like "MLY|1234...|abcd...").
# Get one at https://www.mapillary.com/dashboard/developers — create an app,
# then copy the "Client token". This token is PUBLIC by nature (it ships inside
# the WebView), which is fine for Mapillary client tokens. It is required both
# by the panorama viewer (mapillary-js) and by the pool builder.
VITE_MAPILLARY_ACCESS_TOKEN=MLY|xxxxxxxxxxxxxxxx|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default multiplayer server URL the client connects to on first launch.
# Can be overridden in-app (Settings → Server). For local + tunnel dev this is
# typically a wss:// URL from Cloudflare Tunnel / ngrok, e.g.:
#   wss://geo.example.trycloudflare.com/ws
# For same-machine browser testing against a local server:
#   ws://127.0.0.1:8787/ws
VITE_DEFAULT_SERVER_URL=ws://127.0.0.1:8787/ws

# OPTIONAL: MapTiler key for nicer labelled vector tiles on the guess map.
# Leave empty to use free OSM raster tiles (labels already baked in, no key).
VITE_MAPTILER_KEY=

# ─── Pool builder only (tools/pool-builder) ──────────────────────────────────
# The builder reads the same Mapillary token from here (Node, not Vite-prefixed).
MAPILLARY_TOKEN=MLY|xxxxxxxxxxxxxxxx|xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
